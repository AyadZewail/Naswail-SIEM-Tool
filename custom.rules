alert tcp any any -> any any (msg:"SQL Injection"; pcre:"/UNION|SELECT|DROP|INSERT|DELETE/i"; sid:1000008; rev:1;)
alert icmp any any -> any any (msg:"ICMP Ping"; sid:1000002; rev:1;)
alert tcp any any -> any any (msg:"SYN Flood"; flags:S; threshold:type threshold, track by_src, count 50, seconds 5; sid:2000003; rev:1;)
alert udp any any -> any any (msg:"UDP Flood"; threshold:type threshold, track by_src, count 100, seconds 1; classtype:attempted-dos; sid:1000001; rev:1;)

